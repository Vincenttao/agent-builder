# Python cache and local environments
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/

# Local configuration and secrets — never commit
.env
.env.*
!.env.example
!.env.test.example

# Editor swap files / metadata
*.swp
*.swo
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json

# Node / TS
node_modules/
.pnp
.pnp.js
.next/
out/
dist/
build/
*.tsbuildinfo
coverage/

# Test / coverage
.pytest_cache/
.nyc_output/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Workspace runtime data (gitignored per P0 plan §2)
workspace/generated/
workspace/exports/
workspace/runs/
workspace/logs/
workspace/*.db
workspace/*.db-journal

# misc logs
*.log
