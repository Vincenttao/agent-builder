# Agent Builder — environment configuration (P1).
# Copy to `.env` and fill in. `.env` is gitignored; never commit real keys.
# CI / E2E run with the defaults (mock provider, no key required).

# --- Spec parser (Phase 9) ---
# deterministic = keyword-match the two demo prompts only; llm = always LLM;
# hybrid (default) = demo prompts use deterministic, everything else uses LLM.
SPEC_PARSER_MODE=hybrid
# mock (default, no key) | openai-compatible (real Chat Completions gateway)
SPEC_LLM_PROVIDER=mock
SPEC_LLM_MODEL=qwen-plus
SPEC_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SPEC_LLM_API_KEY=
SPEC_LLM_TIMEOUT_SECONDS=45
SPEC_LLM_MAX_RETRIES=2

# --- Code generation engine (Phase 10/11) ---
# template (default, deterministic) | opencode (real OpenCode) | mock
CODEGEN_ENGINE=template
# When CODEGEN_ENGINE=opencode, require a real opencode binary (else fallback).
OPENCODE_REQUIRE_REAL=false
OPENCODE_BIN=opencode
OPENCODE_PROVIDER=mock
OPENCODE_MODEL=
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
# env = inject OPENCODE_*/provider key via sandbox env allowlist (logs redacted);
# project_config = write only non-secret project config (key still via env);
# mounted_user_config = read-only mount of user-level opencode config.
OPENCODE_CONFIG_MODE=env
# Real OpenCode jobs must NOT use `none`; use controlled or openjiuwen_only.
OPENCODE_NETWORK_POLICY=controlled
OPENCODE_TIMEOUT_SECONDS=180
OPENCODE_MAX_RETRIES=2
OPENCODE_WORKDIR_MODE=project
OPENCODE_ALLOW_FALLBACK=true

# --- P1 Beta feature flags (Phase 12/15) ---
FEATURE_SPEC_CONFIRMATION=true
FEATURE_REPAIR_RETRY=true
FEATURE_VERSION_DIFF=true
FEATURE_RUN_LOG_VIEWER=true
FEATURE_PROMPT_TEMPLATES=true
FEATURE_GITHUB_EXPORT=false

# --- Runtime ---
PORT=3001
APP_NAME=agent-builder-api
# METADATA_DB_PATH=:memory: for tests; default workspace/metadata.db in dev.
# WORKSPACE_DIR=
