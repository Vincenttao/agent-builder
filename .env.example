# Agent Builder — environment configuration (P4).
# Copy to `apps/api/.env` and fill in. `.env` is gitignored; never commit real keys.
# CI / E2E run with the defaults (mock provider, no key required).

# --- Spec parser ---
# All prompts go through the LLM parser (no deterministic demo bypass).
# mock (default, no key, CI) | openai-compatible (real Chat Completions gateway)
SPEC_LLM_PROVIDER=mock
SPEC_LLM_MODEL=deepseek-v4-pro
SPEC_LLM_BASE_URL=https://api.deepseek.com/v1
SPEC_LLM_API_KEY=
SPEC_LLM_TIMEOUT_SECONDS=60
SPEC_LLM_MAX_RETRIES=2

# --- Code generation engine ---
# template = deterministic TemplateEngine (lightweight, test-only).
# opencode = real OpenCode via Docker sandbox (P4 recommended).
CODEGEN_ENGINE=opencode
# Set to true to execute real `opencode run` via SandboxService.
OPENCODE_REQUIRE_REAL=true
# Provider / model / key injected into sandbox when set. Fill in for real OpenCode:
OPENCODE_PROVIDER=deepseek
OPENCODE_MODEL=deepseek-v4-flash
OPENCODE_BASE_URL=https://api.deepseek.com/v1
OPENCODE_API_KEY=
# Real OpenCode jobs must NOT use `none`; use controlled or openjiuwen_only.
OPENCODE_NETWORK_POLICY=controlled
OPENCODE_TIMEOUT_SECONDS=300
OPENCODE_MAX_RETRIES=2
# P4: When OPENCODE_REQUIRE_REAL=true but `opencode` binary is missing:
#   false (default) — fail loud with diagnostics (real path only, no silent fallback)
#   true            — fall back to TemplateEngine (emits {fallback:true} event)
OPENCODE_ALLOW_FALLBACK=false
# P4: manual Template-fallback endpoint. Default disabled (fail-loud principle).
# Set to "true" to enable POST /api/generations/:id/fallback as a dev rescue hatch.
ENABLE_TEMPLATE_FALLBACK=false
# v1 = standalone opencode v1.x (host: --dangerously-skip-permissions)
OPENCODE_CLI_STYLE=v1

# --- Agent runtime LLM (P4: separate from generation LLM) ---
# Generated Agents read these at runtime via environment variables.
# When RUN_LLM_* are unset, falls back to OPENCODE_* with a deprecation warning (P5 will remove).
RUN_LLM_PROVIDER=deepseek
RUN_LLM_API_KEY=
RUN_LLM_BASE_URL=https://api.deepseek.com/v1
RUN_LLM_MODEL=deepseek-v4-flash

# --- Runtime ---
PORT=3001
APP_NAME=agent-builder-api
# METADATA_DB_PATH=:memory: for tests; default workspace/metadata.db in dev.
# WORKSPACE_DIR=

# Cloud server: write this to apps/web/.env.local (NOT apps/api/.env).
# NEXT_ALLOWED_DEV_ORIGINS=your-public-ip
