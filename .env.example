# Agent Builder — environment configuration (P2).
# Copy to `apps/api/.env` and fill in. `.env` is gitignored; never commit real keys.
# CI / E2E run with the defaults (mock provider, no key required).

# --- Spec parser ---
# All prompts go through the LLM parser (no deterministic demo bypass).
# mock (default, no key) | openai-compatible (real Chat Completions gateway)
SPEC_LLM_PROVIDER=mock
SPEC_LLM_MODEL=deepseek-chat
SPEC_LLM_BASE_URL=https://api.deepseek.com/v1
SPEC_LLM_API_KEY=
SPEC_LLM_TIMEOUT_SECONDS=60
SPEC_LLM_MAX_RETRIES=2

# --- Code generation engine (Phase 10/11) ---
# template (default, deterministic) | opencode (real OpenCode via SandboxService) | mock
CODEGEN_ENGINE=template
# When CODEGEN_ENGINE=opencode, set to true to execute real `opencode run` via
# SandboxService. false = emit opencode_* events around TemplateEngine (CI default).
OPENCODE_REQUIRE_REAL=false
# Provider / model / key injected into sandbox when set. Fill in for real OpenCode:
OPENCODE_PROVIDER=
OPENCODE_MODEL=
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
# Real OpenCode jobs must NOT use `none`; use controlled or openjiuwen_only.
OPENCODE_NETWORK_POLICY=controlled
OPENCODE_TIMEOUT_SECONDS=180
OPENCODE_MAX_RETRIES=2
OPENCODE_ALLOW_FALLBACK=true
# v0 = opencode GitHub Release binary (Docker sandbox, default)
# v1 = standalone opencode v1.x (host: --dangerously-skip-permissions --format json)
OPENCODE_CLI_STYLE=v0

# --- Runtime ---
PORT=3001
APP_NAME=agent-builder-api
# METADATA_DB_PATH=:memory: for tests; default workspace/metadata.db in dev.
# WORKSPACE_DIR=
